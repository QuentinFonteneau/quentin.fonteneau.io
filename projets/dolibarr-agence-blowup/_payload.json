[{"data":1,"prerenderedAt":86},["ShallowReactive",2],{"document":3,"content-query-NqATSVv7KN":61},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":7,"img":9,"project_type":10,"project_skills":11,"project_url":7,"draft":6,"readingTime":14,"body":19,"_type":55,"_id":56,"_source":57,"_file":58,"_stem":59,"_extension":60},"/projets/dolibarr-agence-blowup","projets",false,"","Dolibarr - Agence BlowUp","dolibarr-agenceblowup","Freelance",[12,13],"Gestion de serveur","Docker",{"text":15,"minutes":16,"time":17,"words":18},"1 min read",0.5,30000,100,{"type":20,"children":21,"toc":52},"root",[22,45],{"type":23,"tag":24,"props":25,"children":26},"element","project-header",{},[27,40],{"type":23,"tag":28,"props":29,"children":30},"p",{},[31,34,38],{"type":32,"value":33},"text","Pour répondre à ses besoins croissants en matière de gestion interne, l'agence BlowUp m'a contacté afin de mettre une solution ERP / CRM.\nAprès quelques recherches, j'ai découvert Dolibarr, une solution ERP/CRM open-source reconnue pour sa flexibilité et son efficacité.  Dans un premier temps, j'ai donc proposé cette solution à l'agence pour une phase de test qui s'est avérée concluante.",{"type":23,"tag":35,"props":36,"children":37},"br",{},[],{"type":32,"value":39},"\nJ'ai ensuite pu finaliser l'installation d'un serveur avec une mise en place de sauvegarde automatique en cas de problème.",{"type":23,"tag":28,"props":41,"children":42},{},[43],{"type":32,"value":44},"Cette décision permet à l'agence BlowUp de centraliser des processus essentiels tels que la facturation, la relation client, et la coordination des projets.",{"type":23,"tag":46,"props":47,"children":51},"block-image",{":legend":48,"alt":49,"src":50},"null","Capture d'écran de la page de connexion de Dolibarr.","/img/projects/content/dolibarr-agenceblowup.png",[],{"title":7,"searchDepth":53,"depth":53,"links":54},2,[],"markdown","content:projets:dolibarr-agence-blowup.md","content","projets/dolibarr-agence-blo